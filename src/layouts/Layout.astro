---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = "ANTE | Estudio de Fotografía Profesional",
  description = "ANTE Estudio de Fotografía: retratos minimalistas, profesionales y con personalidad para personas y empresas en CDMX. Fotografía honesta que refleja tu esencia.",
  canonical: canonicalProp,
  ogImage = "https://www.ante.photo/img/Fondo3.jpg",
  noindex = false,
} = Astro.props;

const siteUrl = "https://www.ante.photo";
const rawPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/');
const canonical = canonicalProp ?? (siteUrl + rawPath);

const pageNames: Record<string, string> = {
  '/': 'Inicio',
  '/contacto': 'Contacto',
  '/nosotros': 'Nosotros',
  '/galeria': 'Galería',
  '/mas': 'Más',
  '/aviso-privacidad': 'Aviso de Privacidad',
  '/clientes': 'Clientes',
};
const currentPageName = pageNames[rawPath] ?? 'Página';

const breadcrumbItems = rawPath === '/'
  ? [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl + '/' }]
  : [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl + '/' },
      { "@type": "ListItem", "position": 2, "name": currentPageName, "item": canonical },
    ];

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "ANTE Estudio de Fotografía",
      "url": siteUrl + "/",
      "sameAs": ["https://www.instagram.com/ante.estudio"],
      "publisher": {
        "@type": "Organization",
        "name": "ANTE Estudio de Fotografía",
        "logo": { "@type": "ImageObject", "url": siteUrl + "/favicon-512.png" },
      },
    },
    {
      "@type": "PhotographyBusiness",
      "name": "ANTE Estudio de Fotografía",
      "url": siteUrl,
      "logo": { "@type": "ImageObject", "url": siteUrl + "/favicon-512.png" },
      "image": siteUrl + "/img/Fondo3.jpg",
      "telephone": "+52-595-122-0554",
      "email": "contacto@ante.photo",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "addressCountry": "MX",
      },
      "priceRange": "$$",
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
        "opens": "09:00",
        "closes": "18:00",
      }],
      "sameAs": ["https://www.instagram.com/ante.estudio"],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": 5,
        "bestRating": 5,
        "ratingCount": 7,
      },
      "description": "Estudio de fotografía profesional en Ciudad de México especializado en retratos minimalistas, corporativos y artísticos. Sesiones desde $900 MXN.",
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems,
    },
  ],
};
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow,max-image-preview:large"}>
  <title>{title}</title>

  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="preload" href="/img/Fondo3.jpg" as="image">

  <meta name="description" content={description}>
  <meta name="keywords" content="fotografía profesional, retratos minimalistas, estudio fotográfico CDMX, retratos corporativos, fotografía artística, sesión de fotos profesional">
  <meta name="author" content="ANTE Estudio Fotográfico">
  <meta name="geo.region" content="MX-CMX">
  <meta name="geo.placename" content="Ciudad de México">
  <meta name="geo.position" content="19.4326;-99.1332">
  <meta name="ICBM" content="19.4326, -99.1332">
  <link rel="canonical" href={canonical}>

  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:url" content={canonical}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="ANTE">
  <meta property="og:locale" content="es_MX">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)}></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;1,300&display=swap" rel="stylesheet">
  
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-REE0NDQ50Y"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-REE0NDQ50Y');
  </script>
</head>
<body>
  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <header>
    <nav>
      <a href="/" class="nav-logo">Ante</a>
      <ul class="nav-links">
        <li><a href="/#galeria">Galería</a></li>
        <li><a href="/nosotros">Nosotros</a></li>
        <li><a href="/contacto">Contacto</a></li>
        <li><a href="/clientes">Clientes</a></li>
        <li><a href="/mas">Más</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer itemscope itemtype="https://schema.org/Organization">
    <div class="footer-logo" itemprop="name">A N T E · Estudio de Fotografía</div>
    <address class="footer-info">
      <a href="mailto:contacto@ante.photo" itemprop="email">contacto@ante.photo</a><br>
      <a href="tel:+525951220554" itemprop="telephone" class="footer-tel">+52 595 122 0554</a><br>
      <span itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
        <span itemprop="addressLocality">Ciudad de México</span> · <span itemprop="addressCountry">México</span>
      </span>
    </address>
  </footer>

  <script is:inline>
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    cursor.style.left = mx + 'px';
    cursor.style.top  = my + 'px';
  });

  function animateRing() {
    rx += (mx - rx) * 0.12;
    ry += (my - ry) * 0.12;
    ring.style.left = rx + 'px';
    ring.style.top  = ry + 'px';
    requestAnimationFrame(animateRing);
  }
  animateRing();

  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => {
      ring.style.width = '56px';
      ring.style.height = '56px';
      ring.style.borderColor = 'rgba(200,184,154,0.6)';
    });
    el.addEventListener('mouseleave', () => {
      ring.style.width = '36px';
      ring.style.height = '36px';
      ring.style.borderColor = 'var(--accent)';
    });
  });

  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Sticky gallery
  (function () {
    const wrapper  = document.getElementById('galeriaWrapper');
    if (!wrapper) return;
    const slides   = wrapper.querySelectorAll('.galeria-slide');
    const contents = wrapper.querySelectorAll('.galeria-slide-content');
    const fill     = document.getElementById('galeriaFill');
    const count    = document.getElementById('galeriaCount');
    const N = slides.length;

    function clamp(v, a, b) { return v < a ? a : v > b ? b : v; }
    function easeInOut(t)   { return t < 0.5 ? 4*t*t*t : 1 - (-2*t+2)**3/2; }

    function update() {
      const scrolled = -wrapper.getBoundingClientRect().top;
      const total    = wrapper.offsetHeight - window.innerHeight;
      // Don't bail at scrolled==0 — we need to set initial CSS vars
      if (total <= 0) return;

      const p = clamp(scrolled / total, 0, 1);

      slides.forEach((slide, d) => {
        // Continuous offset for Rocola style
        const activeIndex = p * (N - 1);
        const offset = d - activeIndex;
        const absOffset = Math.abs(offset);

        slide.style.setProperty('--offset', offset);
        slide.style.setProperty('--abs-offset', absOffset);

        // Z-Index: Center image has the highest z-index
        slide.style.zIndex = Math.round(100 - absOffset * 10);

        // Text opacity peaks strictly at offset 0
        const opacity = clamp(1 - absOffset * 2.5, 0, 1);
        const textOpacity = easeInOut(opacity);
        
        contents[d].style.opacity    = textOpacity;
        contents[d].style.visibility = textOpacity > 0.01 ? 'visible' : 'hidden';
      });

      const active = Math.min(N - 1, Math.floor(p * N));
      if (fill)  fill.style.width  = `${((active + 1) / N) * 100}%`;
      if (count) count.textContent = `0${active + 1} / 0${N}`;
    }

    let rafPending = false;
    window.addEventListener('scroll', () => {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(() => { update(); rafPending = false; });
    }, { passive: true });

    // Run once immediately to set correct initial state
    update();
  })();

  // Duplicate marquee items for seamless infinite loop
  document.querySelectorAll('.marquee-track').forEach(track => {
    const clone = track.innerHTML;
    track.insertAdjacentHTML('beforeend', clone.replace(/id="[^"]*"/g, '').replace(/<img /g, '<img aria-hidden="true" '));
  });
  </script>
</body>
</html>
