---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Más | ANTE Estudio de Fotografía">
<!-- VIDEO BG -->
<video class="video-bg" id="bgVideo" autoplay muted loop playsinline preload="metadata" poster="/img/Fondo4.png">
  <source src="/Dawn Timelapse Video.mp4" type="video/mp4">
</video>
<img id="bgFallback" src="/img/Fondo4.png" alt="Fondo ANTE Estudio" style="position:fixed;top:0;left:0;width:100vw;height:100vh;object-fit:cover;z-index:-1;filter:brightness(0.55) contrast(1.05);display:none;">
<div class="video-overlay"></div>

<div class="center-wrap">
  <div class="foro-content">
    <p class="foro-eyebrow">También ofrecemos</p>
    <h1 class="foro-title">Renta de foro<br>en la Ciudad de México</h1>
    <a href="https://forocolibri.com" class="foro-link" target="_blank" rel="noopener">
      <img src="img/Foro colibri.png" alt="Logo Foro Colibrí" class="foro-logo">
      <span class="foro-link-text">forocolibri.com</span>
    </a>
  </div>
</div>



<style is:global>

    :root {
      --ink: #0d0d0b;
      --paper: #f5f2ed;
      --bone: #e8e3da;
      --ash: #9a9690;
      --char: #1c1b18;
      --mist: #ccc8c0;
      --accent: #f5f5e9;
      --f-serif: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      --f-sans: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      --f-mono: 'DM Mono', 'Courier New', monospace;
      --fs-label: 0.62rem;
      --fs-body: 0.9rem;
      --fs-micro: 0.58rem;
      --ls-label: 0.3em;
      --ls-wide: 0.4em;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--ink);
      color: var(--paper);
      font-family: var(--f-sans);
      font-weight: 300;
      overflow: hidden;
      height: 100vh;
      cursor: none;
    }

    .cursor {
      position: fixed;
      width: 8px; height: 8px;
      background: var(--paper);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      transition: transform 0.1s ease, opacity 0.2s;
    }
    .cursor-ring {
      position: fixed;
      width: 36px; height: 36px;
      border: 0.5px solid var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: transform 0.25s ease, width 0.2s, height 0.2s, opacity 0.2s;
    }

    /* VIDEO BG */
    .video-bg {
      position: fixed;
      top: 0; left: 0;
      width: 100vw; height: 100vh;
      object-fit: cover;
      z-index: -1;
      filter: brightness(0.55) contrast(1.05);
    }
    .video-overlay {
      position: fixed;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(13,13,11,0.3) 0%,
        rgba(13,13,11,0.1) 40%,
        rgba(13,13,11,0.5) 100%
      );
      z-index: 0;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 2rem 4rem;
    }
    .nav-logo {
      font-family: 'Marion', Georgia, serif;
      font-size: 1.1rem;
      font-weight: 400;
      letter-spacing: var(--ls-wide);
      color: var(--paper);
      text-decoration: none;
      text-transform: uppercase;
    }
    .nav-links {
      display: flex;
      gap: 3rem;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--f-mono);
      font-size: var(--fs-label);
      letter-spacing: var(--ls-label);
      color: var(--ash);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.3s;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--paper); }

    /* CENTER CONTENT */
    .center-wrap {
      position: fixed;
      inset: 0;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .foro-content {
      text-align: center;
      opacity: 0;
      animation: fadeup 1.2s 0.5s forwards;
    }
    .foro-eyebrow {
      font-family: var(--f-mono);
      font-size: var(--fs-label);
      letter-spacing: var(--ls-wide);
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }
    .foro-eyebrow::before, .foro-eyebrow::after {
      content: '';
      display: block;
      width: 32px; height: 0.5px;
      background: var(--accent);
    }
    .foro-title {
      font-family: var(--f-serif);
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 3rem;
      color: var(--paper);
    }
    .foro-link {
      display: inline-flex;
      align-items: center;
      gap: 1.2rem;
      text-decoration: none;
      color: var(--paper);
      transition: transform 0.3s;
    }
    .foro-link:hover { transform: translateY(-4px); }
    .foro-logo {
      width: clamp(56px, 8vw, 80px);
      height: clamp(56px, 8vw, 80px);
      object-fit: cover;
      border-radius: 50%;
      background: #fff;
    }
    .foro-link-text {
      font-family: var(--f-mono);
      font-size: var(--fs-label);
      letter-spacing: var(--ls-wide);
      color: var(--ash);
      text-transform: uppercase;
      position: relative;
      transition: color 0.3s;
    }
    .foro-link:hover .foro-link-text { color: var(--paper); }
    .foro-link-text::after {
      content: '';
      position: absolute;
      left: 0; bottom: -4px;
      width: 100%; height: 0.5px;
      background: currentColor;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s;
    }
    .foro-link:hover .foro-link-text::after { transform: scaleX(1); }

    @keyframes fadeup {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
      nav { padding: 1.5rem 1.5rem; }
      .nav-links { gap: 1.5rem; }
    }
  
</style>

<script is:inline>
(() => {

  // Cursor
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    cursor.style.left = mx + 'px';
    cursor.style.top  = my + 'px';
  });

  function animateRing() {
    rx += (mx - rx) * 0.12;
    ry += (my - ry) * 0.12;
    ring.style.left = rx + 'px';
    ring.style.top  = ry + 'px';
    requestAnimationFrame(animateRing);
  }
  animateRing();

  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => {
      ring.style.width = '56px';
      ring.style.height = '56px';
      ring.style.borderColor = 'rgba(200,184,154,0.6)';
    });
    el.addEventListener('mouseleave', () => {
      ring.style.width = '36px';
      ring.style.height = '36px';
      ring.style.borderColor = 'var(--accent)';
    });
  });

  // Video fallback
  (function() {
    const video = document.getElementById('bgVideo');
    const fallback = document.getElementById('bgFallback');
    const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
    const isSaveData = conn && conn.saveData;
    const isLowNetwork = conn && (['slow-2g','2g'].includes(conn.effectiveType || ''));

    function showFallback() {
      if (video) { video.pause(); video.style.display = 'none'; }
      if (fallback) fallback.style.display = 'block';
    }

    if (!video) return;
    if (isSaveData || isLowNetwork) { showFallback(); return; }

    video.muted = true;
    video.playsInline = true;

    const tryPlay = () => {
      const p = video.play && video.play();
      if (p && typeof p.then === 'function') p.catch(() => {});
    };
    tryPlay();

    setTimeout(() => {
      if (video.paused || video.readyState < 2) showFallback();
    }, 1500);

    document.addEventListener('visibilitychange', () => {
      if (!document.hidden && fallback && fallback.style.display !== 'block') tryPlay();
    });
  })();

})();
</script>

</Layout>
